{
  "name": "vorldx-adgorithm-lab",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prerender": "vite build && react-snap",
    "preview": "vite preview"
  },
  "reactSnap": {
    "source": "dist",
    "minifyHtml": {
      "collapseWhitespace": false
    },
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "include": [
      "/",
      "/about",
      "/services",
      "/pricing",
      "/blog",
      "/careers",
      "/contact"
    ],
    "skipThirdPartyRequests": true,
    "maxConcurrentRoutes": 1
  },
  "dependencies": {
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.97",
    "clsx": "^2.1.1",
    "framer-motion": "^11.0.0",
    "lenis": "^1.3.25",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^6.22.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "vanta": "^0.5.24"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.4.19",
    "vite": "^5.2.0"
  }
}
